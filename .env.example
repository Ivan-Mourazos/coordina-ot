# Copia este fichero a .env.local y rellena las credenciales (NO commitear .env.local).

# Origen de datos: mock (desarrollo sin BD) | rps (SQL Server de RPS, red de oficina)
DATASOURCE=mock

# SQL Server de RPS
RPS_DB_HOST=
RPS_DB_PORT=1433
RPS_DB_DATABASE=
RPS_DB_USER=
RPS_DB_PASSWORD=
# Cifrado TLS; TRUST_SERVER_CERTIFICATE=true si el certificado es autofirmado (habitual en servidor interno)
RPS_DB_ENCRYPT=true
RPS_DB_TRUST_SERVER_CERTIFICATE=true
