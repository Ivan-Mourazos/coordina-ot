# Copia este fichero a .env.local y rellena las credenciales (NO commitear .env.local).

# Origen de datos: mock (desarrollo sin BD) | rps (SQL Server de RPS, red de oficina o VPN)
DATASOURCE=mock

# SQL Server de RPS (192.168.0.124; OJO: .128 es el servidor de ARCHIVOS, no el de BD).
# La "BD de OT" es la vista dbo.TGM_PENDIENTE_OT y vive DENTRO de RPSNext.
RPS_DB_HOST=
RPS_DB_PORT=1433
RPS_DB_DATABASE=RPSNext
RPS_DB_USER=
RPS_DB_PASSWORD=
# El servidor es SQL Server 2014: su TLS no negocia con Node moderno (socket hang up
# en el handshake) → encrypt=false en red interna/VPN. Si actualizan el servidor, probar true.
RPS_DB_ENCRYPT=false
RPS_DB_TRUST_SERVER_CERTIFICATE=true
# Timeout de consulta en ms (la vista TGM_PENDIENTE_OT tarda 7-15 s según la hora)
RPS_DB_REQUEST_TIMEOUT=60000

# Carpeta con los PDF escaneados de pedidos: {carpeta}/{año}/{codigo}.pdf
# El proceso del servidor web necesita permiso de lectura en el share.
# La app elige la variable SEGÚN la plataforma, así el mismo .env.local vale en
# Windows (desarrollo) y Linux (deploy) sin editar nada al cambiar de máquina:
#   · Linux (deploy): RPS_PEDIDOS_PDF_DIR = punto de montaje CIFS.
#   · Windows (dev):  RPS_PEDIDOS_PDF_DIR_WIN = ruta UNC (por VPN).
# Cada una tiene default útil (UNC en Windows, /mnt/rps-pedidos en Linux); rellena
# solo si tu ruta difiere del default.
RPS_PEDIDOS_PDF_DIR=/mnt/rps-pedidos
RPS_PEDIDOS_PDF_DIR_WIN=\\192.168.0.128\RPS\VENTAS\PEDIDOS
